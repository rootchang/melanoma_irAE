ICBresponse_info = read.csv(paste0(processed_dir, "GSE176307_clinicInfo.csv"))
ICBresponse_info$SampleID = sub(".*\\s", "", ICBresponse_info$title)
ICBresponse_info = ICBresponse_info[c(5,15,22,24,26,32)]
colnames(ICBresponse_info) = c("OS_event", "ICBR", "OS_time", "PFS_time", "PFS_event","SampleID")
ICBresponse_info$OS_event[ICBresponse_info$OS_event == "Yes"] = 1
ICBresponse_info$OS_event[ICBresponse_info$OS_event == "No"] = 0
ICBresponse_info$PFS_event[ICBresponse_info$PFS_event == "Yes"] = 1
ICBresponse_info$PFS_event[ICBresponse_info$PFS_event == "No"] = 0
ICBresponse_info$ICBR[ICBresponse_info$ICBR %in% c("CR", "PR")] = 1
ICBresponse_info$ICBR[ICBresponse_info$ICBR %in% c("PD", "SD")] = 0
# sample ID conversion
sampleID_info = read.csv(paste0(processed_dir, "GSE176307_BACI_Omniseq_Sample_Name_Key_submitted_GEO_v2.csv"))
colnames(sampleID_info) = c("SampleID", "RNAseqID")
ICBresponse_info = merge(ICBresponse_info, sampleID_info, by = "SampleID", all.x = T)
ICBresponse_info$RNAseqID = gsub("-", "\\.", ICBresponse_info$RNAseqID)
ICBresponse_info$ICBR = as.numeric(ICBresponse_info$ICBR)
ICBresponse_info$OS_event = as.numeric(ICBresponse_info$OS_event)
ICBresponse_info$OS_time = as.numeric(ICBresponse_info$OS_time)/30
ICBresponse_info$PFS_event = as.numeric(ICBresponse_info$PFS_event)
ICBresponse_info$PFS_time = as.numeric(ICBresponse_info$PFS_time)
geneExpr_TPM_Kim <- fpkm_to_tpm(geneExpr_GSE176307)
# log1p TPM
geneExpr_logTPM_Kim = log1p(geneExpr_TPM_Kim)
if (sigScore_method == "log1p_mean"){
geneExpr = data.frame(geneExpr = colMeans(geneExpr_logTPM_Kim[intersect(candi_geneSig, rownames(geneExpr_TPM_Kim)),,drop= F]))
}else if (sigScore_method %in% c("ssgsea", "gsva")){
expr_mat = as.matrix(geneExpr_logTPM_Kim)
geneExpr <- gsva(expr_mat, gene_set_list, method = sigScore_method)
geneExpr = data.frame(geneExpr = t(geneExpr))
}else{
error("Unrecognized signature score method!")
}
colnames(geneExpr) = c("geneExpr")
geneExpr$RNAseqID = rownames(geneExpr)
predictor <- geneExpr
cancerData = merge(predictor, ICBresponse_info[c("RNAseqID", "ICBR")], by = "RNAseqID", all.x = F)
colnames(cancerData) = c("PatientID", "Score", "ICB_R")
cancerData = na.omit(cancerData)
# Calculate AUC and CI for all samples
roc_result=roc(cancerData$ICB_R,cancerData$Score, direction="<",levels=c(0, 1)) # direction: control < case group
auc_RecR = roc_result$auc[1]
auc_95CI = c(ci.auc(roc_result)[1],ci.auc(roc_result)[3])
if (auc_RecR > 0.5){
auc_p=roc.area(cancerData$ICB_R,cancerData$Score)
}else{
auc_p=roc.area(cancerData$ICB_R,-cancerData$Score)
}
p_RecR = auc_p$p.value
print(paste("AUC:", auc_RecR, "  pval:", p_RecR))
AUC_result_df <- rbind(AUC_result_df, data.frame(
dataset = "GSE176307",
cancerType = "advanced UC",
seqType = "Bulk",
CellType_of_Interest = "-",
measurement_TimePt = "Unclear",
Drug = "aPD1/aPDL1",
SampleSize = nrow(cancerData),
AUC = auc_RecR,
p = p_RecR
))
data_plot = merge(predictor, ICBresponse_info[c("RNAseqID", "OS_time", "OS_event")], by = "RNAseqID", all.x = F)
data_plot$RNAseqID = NULL
colnames(data_plot) = c("Score", "OS_time", "OS_event")
data_plot$Score <- ifelse(
is.na(data_plot$Score), NA,
ifelse(data_plot$Score <= quantile(data_plot$Score, quantile_cutoff, na.rm = TRUE), 0, 1)
)
##### OS
cancerData=data.frame(data_plot$Score,data_plot$OS_time,data_plot$OS_event)
cancerData = na.omit(cancerData)
colnames(cancerData) = c("Score", "OS_Months", "OS_Event")
sfit = survfit(Surv(OS_Months,OS_Event) ~ Score, data=cancerData)
scox = coxph(Surv(OS_Months,OS_Event)~Score, data=cancerData)
scox_coef = summary(scox)$coefficients
HR_value = scox_coef[2] # hazard ratio
Z_value=scox_coef[4]
P_value=scox_coef[5]
HR_CI = exp(confint(scox))
print(paste(c('OS', round(HR_value,2), round(P_value,5)), collapse= " "))
OS_result_df <- rbind(OS_result_df, data.frame(
dataset = "GSE176307",
cancerType = "advanced UC",
seqType = "Bulk",
CellType_of_Interest = "-",
measurement_TimePt = "Unclear",
Drug = "aPD1/aPDL1",
SampleSize = nrow(cancerData),
HR = HR_value,
p = P_value
))
}
all_info_list = list()

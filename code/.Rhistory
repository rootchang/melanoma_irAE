###################################### genes and signatures predictive power comparison ######################################
# datasets <- c("Luc", "Uppaluri", "Bill", "Luoma_PBMC", "Luoma_Tissue", "IMCISION_sc", "GSE159067", "GSE93157(HNSCC)")
# drug_name <- c("aPD1/PDL1; aPDL1+aCTLA4", "aPD1", "aPD1 (palliative)", "aPD1 (neoadjuvant)", "aPD1; aPD1+aCTLA4 (neoadjuvant)", "aPD1; aPD1+aCTLA4 (neoadjuvant)", "aPD1/PDL1", "aPD1")
# cancer_type <- c("R/M HNSCC", "locally advanced, HPV-unrelated HNSCC", "primary/locoregional recurrences/metastatic HNSCC", "newly OCSCC w/o metastases", "newly OCSCC w/o metastases", "primary or recurrent HNSCC (mostly HPV-)", "R/M HNSCC", "HNSCC")
# measurement_timept <- c("Pre", timePt, "Pre", timePt, timePt, timePt, "Unclear", "Pre")
# seq_type <- c("Bulk", "Bulk", "scRNAseq", "CD45+ scRNAseq", "CD45+ scRNAseq", "CD45+ scRNAseq", "Bulk (tageted)", "Bulk (PanCancer 730-Immune Panel)")
# CellType_of_Interest_vec <- c("-", "-", CellType_of_Interest, "All", "All", "All", "-", "-")
datasets <- c("Luc", "Uppaluri", "Bill", "Luoma_PBMC", "Luoma_Tissue", "IMCISION_sc", "GSE159067")
drug_name <- c("aPD1/PDL1; aPDL1+aCTLA4", "aPD1", "aPD1 (palliative)", "aPD1 (neoadjuvant)", "aPD1; aPD1+aCTLA4 (neoadjuvant)", "aPD1; aPD1+aCTLA4 (neoadjuvant)", "aPD1/PDL1")
cancer_type <- c("R/M HNSCC", "locally advanced, HPV-unrelated HNSCC", "primary/locoregional recurrences/metastatic HNSCC", "newly OCSCC w/o metastases", "newly OCSCC w/o metastases", "primary or recurrent HNSCC (mostly HPV-)", "R/M HNSCC")
measurement_timept <- c("Pre", timePt, "Pre", timePt, timePt, timePt, "Unclear")
seq_type <- c("Bulk", "Bulk", "scRNAseq", "CD45+ scRNAseq", "CD45+ scRNAseq", "CD45+ scRNAseq", "Bulk (tageted)")
CellType_of_Interest_vec <- c("-", "-", CellType_of_Interest, "All", "All", "All", "-")
for (ds_i in 1:length(datasets)){
ds <- datasets[ds_i]
drug_name_temp <- drug_name[ds_i]
cancer_type_temp <- cancer_type[ds_i]
measurement_timept_temp <- measurement_timept[ds_i]
seq_type_temp <- seq_type[ds_i]
CellType_of_Interest_temp <- CellType_of_Interest_vec[ds_i]
if (all(is.na(all_info_list[[ds]][[candi_geneSig_name]]))){
next
}
cancerData <- all_info_list[[ds]][c("ICBR", candi_geneSig_name)]
cancerData <- na.omit(cancerData)
# Calculate AUC and CI for all samples
roc_result=roc(cancerData$ICBR,cancerData[[candi_geneSig_name]], direction="<",levels=c(0, 1)) # direction: control < case group
auc_RecR = roc_result$auc[1]
auc_95CI = c(ci.auc(roc_result)[1],ci.auc(roc_result)[3])
if (auc_RecR > 0.5){
auc_p=roc.area(cancerData$ICBR,cancerData[[candi_geneSig_name]])
}else{
auc_p=roc.area(cancerData$ICBR,-cancerData[[candi_geneSig_name]])
}
p_RecR = auc_p$p.value
print(paste(c(ds, 'AUC', round(auc_RecR,2), round(p_RecR,5)), collapse= " "))
AUC_result_df <- rbind(AUC_result_df, data.frame(
dataset = ds,
cancerType = cancer_type_temp,
seqType = seq_type_temp,
CellType_of_Interest = CellType_of_Interest_temp,
measurement_TimePt = measurement_timept_temp,
Drug = drug_name_temp,
SampleSize = nrow(cancerData),
AUC = auc_RecR,
p = p_RecR
))
##### OS
if ("OS_time" %in% colnames(all_info_list[[ds]])){
cancerData <- all_info_list[[ds]][c(candi_geneSig_name, "OS_time", "OS_event")]
colnames(cancerData) = c("Score", "OS_Months", "OS_Event")
cancerData$Score <- ifelse(
is.na(cancerData$Score), NA,
ifelse(cancerData$Score <= quantile(cancerData$Score, quantile_cutoff, na.rm = TRUE), 0, 1)
)
cancerData = na.omit(cancerData)
sfit = survfit(Surv(OS_Months,OS_Event) ~ Score, data=cancerData)
scox = coxph(Surv(OS_Months,OS_Event)~Score, data=cancerData)
scox_coef = summary(scox)$coefficients
HR_value = scox_coef[2] # hazard ratio
Z_value=scox_coef[4]
P_value=scox_coef[5]
HR_CI = exp(confint(scox))
print(paste(c(ds, 'OS', round(HR_value,2), round(P_value,5)), collapse= " "))
OS_result_df <- rbind(OS_result_df, data.frame(
dataset = ds,
cancerType = cancer_type_temp,
seqType = seq_type_temp,
CellType_of_Interest = CellType_of_Interest_temp,
measurement_TimePt = measurement_timept_temp,
Drug = drug_name_temp,
SampleSize = nrow(cancerData),
HR = HR_value,
p = P_value
))
}
##### PFS
if ("PFS_time" %in% colnames(all_info_list[[ds]])){
cancerData <- all_info_list[[ds]][c(candi_geneSig_name, "PFS_time", "PFS_event")]
colnames(cancerData) = c("Score", "PFS_Months", "PFS_Event")
cancerData$Score <- ifelse(
is.na(cancerData$Score), NA,
ifelse(cancerData$Score <= quantile(cancerData$Score, quantile_cutoff, na.rm = TRUE), 0, 1)
)
cancerData = na.omit(cancerData)
sfit = survfit(Surv(PFS_Months,PFS_Event) ~ Score, data=cancerData)
scox = coxph(Surv(PFS_Months,PFS_Event)~Score, data=cancerData)
scox_coef = summary(scox)$coefficients
HR_value = scox_coef[2] # hazard ratio
Z_value=scox_coef[4]
P_value=scox_coef[5]
HR_CI = exp(confint(scox))
print(paste(c(ds,'PFS', round(HR_value,2), round(P_value,5)), collapse= " "))
PFS_result_df <- rbind(PFS_result_df, data.frame(
dataset = ds,
cancerType = cancer_type_temp,
seqType = seq_type_temp,
CellType_of_Interest = CellType_of_Interest_temp,
measurement_TimePt = measurement_timept_temp,
Drug = drug_name_temp,
SampleSize = nrow(cancerData),
HR = HR_value,
p = P_value
))
}
}
library(dplyr)
# Perform full joins by 'dataset' to include all unique datasets across the four dataframes
merged_df <- full_join(AUC_result_df, OS_result_df, by = "dataset", suffix = c(".AUC", ".OS")) %>%
full_join(PFS_result_df, by = "dataset", suffix = c("", ".PFS")) %>%
full_join(MFS_result_df, by = "dataset", suffix = c("", ".MFS"))
# Create final dataframe using coalesce to prioritize non-NA values from AUC -> OS -> PFS -> MFS
final_df <- merged_df %>%
transmute(
dataset = dataset,
cancerType = coalesce(cancerType.AUC, cancerType.OS, cancerType, cancerType.MFS),
seqType = coalesce(seqType.AUC, seqType.OS, seqType, seqType.MFS),
CellType_of_Interest = coalesce(CellType_of_Interest.AUC, CellType_of_Interest.OS, CellType_of_Interest, CellType_of_Interest.MFS),
measurement_TimePt = coalesce(measurement_TimePt.AUC, measurement_TimePt.OS, measurement_TimePt, measurement_TimePt.MFS),
Drug = coalesce(Drug.AUC, Drug.OS, Drug, Drug.MFS)
)
# Define the columns to remove
cols_to_remove <- c("cancerType", "seqType", "CellType_of_Interest", "measurement_TimePt", "Drug")
# Remove those columns from each dataset (if they exist)
AUC_trimmed  <- AUC_result_df[ , !(names(AUC_result_df) %in% cols_to_remove)]
OS_trimmed   <- OS_result_df[ , !(names(OS_result_df) %in% cols_to_remove)]
PFS_trimmed  <- PFS_result_df[ , !(names(PFS_result_df) %in% cols_to_remove)]
MFS_trimmed  <- MFS_result_df[ , !(names(MFS_result_df) %in% cols_to_remove)]
# Merge all data frames by 'dataset'
merged_all_result_df <- merge(
merge(
merge(AUC_trimmed, OS_trimmed, by = "dataset", all = TRUE),
PFS_trimmed, by = "dataset", all = TRUE
),
MFS_trimmed, by = "dataset", all = TRUE
)
merged_all_result_df <- merge(final_df, merged_all_result_df, by = "dataset")
colnames(merged_all_result_df) <- c("dataset", "cancerType", "seqType", "CellType_of_Interest", "measurement_TimePt", "Drug", "SampleSize_AUC", "AUC", "p_AUC", "SampleSize_OS", "HR_OS", "p_OS", "SampleSize_PFS", "HR_PFS", "p_PFS", "SampleSize_MFS", "HR_MFS", "p_MFS")
write.csv(merged_all_result_df, file = paste0("/Users/changt7/Documents/00.PostDocWork/CancerResearch/01.Projects/00.Collaborating_projects/39.Yardena_CRISPR_TranslationFidelity_project/03.Results/Data/", candi_geneSig_name, "_all_ICBcohorts_result.csv"))
